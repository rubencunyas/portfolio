---
import Layout from '../layouts/Layout.astro';

const whatsappNumber = "51987518768";
const whatsappText = encodeURIComponent("Hola Rubén, vi tu página de servicios y quiero cotizar una web o landing.");

const services = [
  {
    label: "01",
    title: "Landing pages para campañas",
    text: "Páginas rápidas, claras y preparadas para convertir tráfico de Meta, Google o referidos en consultas.",
    tags: ["Copy", "Diseño", "Formulario", "WhatsApp"]
  },
  {
    label: "02",
    title: "Web corporativa con criterio comercial",
    text: "Sitios que explican tu oferta, ordenan tus servicios y hacen que tu negocio se perciba serio desde el primer contacto.",
    tags: ["UX/UI", "SEO base", "Mobile-first", "Analytics"]
  },
  {
    label: "03",
    title: "Marca + sistema visual",
    text: "Identidad ligera, piezas base y dirección visual para que tu web, redes y material comercial hablen el mismo idioma.",
    tags: ["Logo refine", "Paleta", "Tipografía", "Plantillas"]
  },
  {
    label: "04",
    title: "Soporte mensual",
    text: "Mantenimiento, ajustes, banners, nuevas secciones y mejoras de conversión para negocios que se mueven cada mes.",
    tags: ["Backups", "Cambios", "Velocidad", "Seguridad"]
  }
];

const process = [
  ["Diagnóstico", "Revisamos tu oferta, público, competencia, objeciones y meta de conversión."],
  ["Mapa de venta", "Defino estructura, mensajes, CTA, secciones y recorrido mobile-first."],
  ["Diseño con intención", "Armo una interfaz visual que se sienta propia, confiable y fácil de escanear."],
  ["Desarrollo ultraligero", "Publico una web rápida, responsive, medible y lista para recibir consultas."],
  ["Mejora continua", "Revisamos señales reales: clics, mensajes, formularios y fricción del usuario."]
];

const cases = [
  {
    title: "Berlitz",
    metric: "+60%",
    label: "mejora de conversión",
    text: "Landings educativas mobile-first para campañas de captación en LATAM.",
    image: "/projects/thumbs/berlitz-landing.webp",
    href: "/projects/berlitz"
  },
  {
    title: "Autoval Service",
    metric: "30 años",
    label: "de confianza mejor comunicada",
    text: "Web premium para convertir reputación offline en presencia digital creíble.",
    image: "/projects/thumbs/autoval-card.webp",
    href: "/projects/autoval"
  },
  {
    title: "Organnical",
    metric: "+2,400",
    label: "pacientes atendidos",
    text: "Plataforma wellness con telemedicina, e-commerce y experiencia de confianza.",
    image: "/projects/thumbs/organnical-card.webp",
    href: "/projects/organnical-sisven"
  }
];

const packages = [
  ["Landing Sprint", "Desde S/900", "Landing de una página para validar una campaña, servicio o captación puntual."],
  ["Presencia Pro", "Desde S/2,500", "Web corporativa + identidad visual ligera para negocios que necesitan verse sólidos."],
  ["Crecimiento Mensual", "Desde S/600/mes", "Soporte, mantenimiento, piezas web y mejoras continuas para vender mejor."]
];

const faqs = [
  ["¿Trabajas solo con WordPress?", "No. Uso la tecnología que conviene al proyecto: Astro, WordPress, landing estática o CMS según el caso."],
  ["¿Puedes ayudar con el texto?", "Sí. La estructura y el copy base forman parte del trabajo, porque una web bonita sin mensaje claro no vende."],
  ["¿La página queda conectada a formularios?", "Sí. En Netlify podemos recibir formularios sin backend adicional, y también conectar WhatsApp, Analytics o herramientas externas."],
  ["¿Cuánto demora una landing?", "Una landing simple puede salir en 7 días si tenemos oferta, contenido base y feedback rápido."]
];
---

<Layout
  title="Servicios web para captar clientes | Rubén Cunyas"
  description="Landing pages, webs corporativas, identidad digital y soporte mensual para negocios peruanos que necesitan verse profesionales y captar más clientes."
>
  <main class="services-page bg-[#f2f2ef] text-[#111111] [font-family:Manrope,Inter,system-ui,sans-serif]">
    <section class="relative isolate overflow-hidden text-white services-hero" id="services-hero">
      <div class="absolute inset-x-0 top-0 h-px bg-white/15"></div>
      <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
      <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
      <div class="hero-blob hero-blob-3" aria-hidden="true"></div>
      <div class="hero-blob hero-blob-4" aria-hidden="true"></div>
      <div class="services-hero-grid" aria-hidden="true"></div>
      <div class="hero-halo" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto flex max-w-7xl items-center justify-between px-5 py-6 sm:px-8 lg:px-12">
        <a href="/" class="text-sm font-extrabold tracking-[0.18em]" aria-label="Volver al portfolio">
          CUNYAS
        </a>
        <nav class="hidden items-center gap-7 text-sm font-bold text-white/70 md:flex" aria-label="Servicios">
          <a class="transition hover:text-[#ff4108]" href="#servicios">Servicios</a>
          <a class="transition hover:text-[#ff4108]" href="#proceso">Proceso</a>
          <a class="transition hover:text-[#ff4108]" href="#contacto">Cotizar</a>
          <a class="transition hover:text-[#ff4108]" href="/">Portfolio</a>
        </nav>
        <a
          href={`https://wa.me/${whatsappNumber}?text=${whatsappText}`}
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-[#ff4108] px-5 text-sm font-extrabold text-white transition hover:bg-[#3031e4]"
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp
        </a>
      </div>

      <div class="mx-auto grid max-w-7xl gap-12 px-5 pb-16 pt-10 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-12 lg:pb-24 lg:pt-16">
        <div class="relative z-10" data-reveal>
          <p class="mb-5 inline-flex rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-extrabold text-[#ff4108]">
            Webs rápidas para vender mejor
          </p>
          <h1 class="max-w-5xl font-display text-6xl font-bold uppercase leading-[0.88] tracking-normal sm:text-8xl lg:text-[9rem]">
            Webs que abren conversaciones.
          </h1>
          <p class="mt-7 max-w-xl text-lg leading-8 text-white/72 sm:text-xl">
            Landing, web e identidad digital para captar clientes con claridad.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#contacto" class="inline-flex min-h-14 items-center justify-center rounded-full bg-[#ff4108] px-8 text-base font-extrabold text-white transition hover:bg-white hover:text-[#111111]">
              Cotizar proyecto
            </a>
            <a href="#casos" class="inline-flex min-h-14 items-center justify-center rounded-full border border-white/20 px-8 text-base font-extrabold text-white transition hover:border-[#3031e4] hover:text-[#ff4108]">
              Ver resultados
            </a>
          </div>
        </div>

        <div class="relative min-h-[430px]" data-reveal>
          <div class="hero-frame absolute right-0 top-0 w-[92%] rounded-[6px] bg-[#3031e4] p-4 shadow-[0_30px_100px_rgba(0,0,0,0.25)]">
            <img
              src="/projects/thumbs/berlitz-landing.webp"
              alt="Ejemplo de landing page diseñada para captar leads"
              width="980"
              height="620"
              class="aspect-[4/3] w-full rounded-[3px] object-cover object-top"
            />
          </div>
          <div class="absolute bottom-8 left-0 max-w-[260px] rounded-[6px] border border-white/12 bg-white p-5 text-[#111111] shadow-[0_24px_70px_rgba(0,0,0,0.28)]">
            <p class="text-5xl font-extrabold leading-none">+60%</p>
            <p class="mt-3 text-sm font-bold leading-6 text-[#696969]">mejora de conversión en landing educativa.</p>
          </div>
          <div class="absolute bottom-0 right-7 rounded-[6px] bg-[#ff4108] px-5 py-3 text-sm font-extrabold text-white">
            Formulario + WhatsApp + medición
          </div>
        </div>
      </div>
      <div class="border-y border-white/10 py-4">
        <div class="marquee flex gap-10 whitespace-nowrap text-sm font-extrabold uppercase tracking-[0.18em] text-white/60">
          <span>Landing pages</span><span>Web corporativa</span><span>Identidad visual</span><span>SEO base</span><span>Soporte mensual</span><span>Analytics</span>
          <span>Landing pages</span><span>Web corporativa</span><span>Identidad visual</span><span>SEO base</span><span>Soporte mensual</span><span>Analytics</span>
        </div>
      </div>
    </section>

    <section id="servicios" class="technical-grid px-5 py-16 sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end" data-reveal>
          <div>
            <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#696969]">Servicios</p>
            <h2 class="mt-3 font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl">
              Diseño, desarrollo y venta puestos en la misma mesa.
            </h2>
          </div>
          <p class="max-w-2xl text-lg leading-8 text-[#696969]">
            No parto desde una plantilla. Parto desde qué necesita entender tu cliente para confiar, preguntar y comprar.
          </p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {services.map((service) => (
            <article class="service-card group relative overflow-hidden rounded-[6px] border border-[#d7d7d2] bg-white p-6 transition duration-300 hover:-translate-y-1 hover:border-[#111111] hover:shadow-[0_22px_70px_rgba(17,17,17,0.10)]" data-reveal>
              <div class="flex items-start justify-between gap-5">
                <span class="rounded-[4px] bg-[#3031e4] px-4 py-2 text-sm font-extrabold text-white">{service.label}</span>
                <span class="grid h-12 w-12 place-items-center rounded-[4px] bg-[#ff4108] text-white transition group-hover:bg-[#3031e4]" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 7L7 17M8 7h9v9" />
                  </svg>
                </span>
              </div>
              <h3 class="mt-8 max-w-xl font-display text-4xl font-bold uppercase leading-[0.96]">{service.title}</h3>
              <p class="mt-4 max-w-2xl leading-8 text-[#696969]">{service.text}</p>
              <div class="mt-7 flex flex-wrap gap-2">
                {service.tags.map((tag) => (
                  <span class="rounded-[4px] border border-[#d7d7d2] px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-[#696969]">{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="proceso" class="bg-white px-5 py-16 sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div class="lg:sticky lg:top-10 lg:self-start" data-reveal>
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#696969]">Proceso</p>
          <h2 class="mt-3 font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl">
            De idea dispersa a página lista para vender.
          </h2>
          <p class="mt-5 text-lg leading-8 text-[#696969]">
            Ordeno la estrategia antes de abrir el diseño. Así la web no termina siendo decoración: termina siendo una herramienta comercial.
          </p>
        </div>
        <div class="space-y-4">
          {process.map(([title, text], index) => (
            <article class="process-row relative grid gap-5 overflow-hidden rounded-[6px] border border-[#d7d7d2] bg-[#f2f2ef] p-5 sm:grid-cols-[90px_1fr_150px] sm:p-0" data-reveal>
              <div class="grid min-h-28 place-items-center bg-[#ff4108] p-5 text-5xl font-extrabold text-white">{String(index + 1).padStart(2, "0")}</div>
              <div>
                <h3 class="font-display text-3xl font-bold uppercase">{title}</h3>
                <p class="mt-2 leading-8 text-[#696969]">{text}</p>
              </div>
              <div class="hidden place-items-center bg-[#3031e4] p-5 text-center text-sm font-extrabold text-white sm:grid">
                Fase {index + 1}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="casos" class="bg-[#111111] px-5 py-16 text-white sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end" data-reveal>
          <div>
            <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#ff4108]">Casos</p>
            <h2 class="mt-3 max-w-3xl font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl">
              Proyectos que ya probaron el enfoque.
            </h2>
          </div>
          <a href="/" class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/20 px-7 font-extrabold text-white transition hover:border-[#3031e4] hover:text-[#ff4108]">
            Ver portfolio
          </a>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {cases.map((item) => (
            <a href={item.href} class="case-card group rounded-[6px] border border-white/10 bg-white/[0.04] p-3 transition hover:-translate-y-1 hover:bg-white/[0.08]" data-reveal>
              <img
                src={item.image}
                alt={`Proyecto ${item.title}`}
                width="760"
                height="570"
                loading="lazy"
                class="aspect-[4/3] w-full rounded-[3px] object-cover object-top"
              />
              <div class="p-4">
                <p class="text-5xl font-extrabold text-[#ff4108]">{item.metric}</p>
                <p class="mt-1 text-sm font-extrabold uppercase tracking-[0.12em] text-[#3031e4]">{item.label}</p>
                <h3 class="mt-5 font-display text-3xl font-bold uppercase">{item.title}</h3>
                <p class="mt-3 leading-7 text-white/70">{item.text}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="px-5 py-16 sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start" data-reveal>
          <div>
            <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#696969]">Paquetes</p>
            <h2 class="mt-3 font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl">
              Tres formas simples de empezar.
            </h2>
          </div>
          <div class="grid gap-4">
            {packages.map(([name, price, text]) => (
              <article class="grid gap-4 rounded-[6px] border border-[#d7d7d2] bg-white p-6 md:grid-cols-[1fr_auto] md:items-center" data-reveal>
                <div>
                  <h3 class="font-display text-3xl font-bold uppercase">{name}</h3>
                  <p class="mt-2 leading-7 text-[#696969]">{text}</p>
                </div>
                <p class="rounded-[6px] bg-[#3031e4] px-5 py-3 text-lg font-extrabold text-white">{price}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="bg-white px-5 py-16 sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div data-reveal>
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#696969]">Contacto</p>
          <h2 class="mt-3 font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl">
            Cuéntame qué quieres vender mejor.
          </h2>
          <p class="mt-5 text-lg leading-8 text-[#696969]">
            Responde lo básico y te escribo para aterrizar alcance, tiempos y una ruta clara. También puedes ir directo por WhatsApp.
          </p>
          <a
            href={`https://wa.me/${whatsappNumber}?text=${whatsappText}`}
            class="mt-8 inline-flex min-h-14 items-center justify-center rounded-full bg-[#111111] px-8 font-extrabold text-white transition hover:bg-[#3031e4]"
            target="_blank"
            rel="noopener noreferrer"
          >
            Escribir por WhatsApp
          </a>
        </div>
        <form
          id="services-form"
          name="servicios"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="rounded-[6px] border border-[#d7d7d2] bg-[#f2f2ef] p-5 sm:p-8"
          data-reveal
        >
          <input type="hidden" name="form-name" value="servicios" />
          <input type="hidden" name="subject" data-remove-prefix value="Nuevo lead desde Servicios (%{submissionId})" />
          <p class="hidden">
            <label>No llenar: <input name="bot-field" /></label>
          </p>
          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">Nombre</span>
              <input required name="nombre" autocomplete="name" class="mt-2 min-h-14 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20" />
            </label>
            <label class="block">
              <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">WhatsApp</span>
              <input required name="telefono" autocomplete="tel" class="mt-2 min-h-14 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20" />
            </label>
            <label class="block">
              <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">Email</span>
              <input required type="email" name="email" autocomplete="email" class="mt-2 min-h-14 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20" />
            </label>
            <label class="block">
              <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">Tipo de proyecto</span>
              <select name="tipo" class="mt-2 min-h-14 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20">
                <option>Landing page</option>
                <option>Web corporativa</option>
                <option>Marca + Web</option>
                <option>Soporte mensual</option>
                <option>No estoy seguro</option>
              </select>
            </label>
          </div>
          <label class="mt-5 block">
            <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">Presupuesto estimado</span>
            <select name="presupuesto" class="mt-2 min-h-14 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20">
              <option>Estoy validando opciones</option>
              <option>S/900 - S/1,500</option>
              <option>S/1,500 - S/3,000</option>
              <option>S/3,000 - S/6,000</option>
              <option>Más de S/6,000</option>
            </select>
          </label>
          <label class="mt-5 block">
            <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#696969]">¿Qué necesitas lograr?</span>
            <textarea required name="mensaje" rows="5" class="mt-2 w-full rounded-[6px] border border-[#d9dde8] bg-white px-4 py-4 text-base outline-none transition focus:border-[#3031e4] focus:ring-4 focus:ring-[#3031e4]/20"></textarea>
          </label>
          <button id="services-submit" class="mt-6 inline-flex min-h-14 w-full items-center justify-center rounded-full bg-[#ff4108] px-8 font-extrabold text-white transition hover:bg-[#3031e4]" type="submit">
            <span id="services-submit-text">Enviar solicitud</span>
          </button>
          <p class="mt-4 text-sm leading-6 text-[#696969]">Recibiré tu mensaje y te responderé por WhatsApp o correo.</p>
          <p id="services-error" class="mt-4 hidden rounded-[6px] border border-[#ff4108]/30 bg-[#ff4108]/10 px-4 py-3 text-sm leading-6 text-[#111111]">
            No pude enviar el formulario. Escríbeme por WhatsApp o a <a class="font-extrabold text-[#3031e4] underline" href="mailto:hello@cunyas.com">hello@cunyas.com</a>.
          </p>
        </form>
      </div>
    </section>

    <section class="px-5 py-16 sm:px-8 lg:px-12 lg:py-24">
      <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[0.7fr_1.3fr]">
        <h2 class="font-display text-5xl font-bold uppercase leading-[0.92] sm:text-7xl" data-reveal>Preguntas rápidas.</h2>
        <div class="space-y-3">
          {faqs.map(([question, answer]) => (
            <details class="group rounded-[6px] border border-[#d7d7d2] bg-white p-5" data-reveal>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-extrabold">
                {question}
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-[4px] bg-[#ff4108] text-white transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 leading-8 text-[#696969]">{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const revealItems = document.querySelectorAll('[data-reveal]');
    revealItems.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${Math.min(index % 6, 5) * 55}ms`);
    });
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });
      revealItems.forEach((item) => observer.observe(item));
    }
  </script>
  <script is:inline>
    const servicesForm = document.getElementById('services-form');
    const servicesSubmit = document.getElementById('services-submit');
    const servicesSubmitText = document.getElementById('services-submit-text');
    const servicesError = document.getElementById('services-error');

    const notifyLeadEmail = async (form) => {
      try {
        await fetch('/.netlify/functions/lead-email', {
          method: 'POST',
          body: new FormData(form)
        });
      } catch {
        // Netlify Forms already captured the lead; email is a secondary alert.
      }
    };

    servicesForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      servicesError.classList.add('hidden');
      servicesSubmitText.textContent = 'Enviando...';
      servicesSubmit.disabled = true;
      servicesSubmit.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(servicesForm)).toString()
        });

        if (!response.ok) {
          throw new Error('No se pudo enviar el formulario.');
        }

        await notifyLeadEmail(servicesForm);
        window.location.href = '/gracias/';
      } catch {
        servicesSubmitText.textContent = 'Intentar de nuevo';
        servicesError.classList.remove('hidden');
        servicesSubmit.disabled = false;
        servicesSubmit.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  </script>
  <script is:inline>
    (function cursorHalo() {
      const hero = document.getElementById('services-hero');
      if (!hero) return;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      let rafId = 0;
      let targetX = 0.5;
      let targetY = 0.4;
      let currentX = 0.5;
      let currentY = 0.4;

      const onPointerMove = (e) => {
        targetX = e.clientX / window.innerWidth;
        targetY = e.clientY / window.innerHeight;
      };

      const animate = () => {
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;
        hero.style.setProperty('--mxp', (100 * currentX).toFixed(2) + '%');
        hero.style.setProperty('--myp', (100 * currentY).toFixed(2) + '%');
        rafId = requestAnimationFrame(animate);
      };

      window.addEventListener('pointermove', onPointerMove, { passive: true });
      rafId = requestAnimationFrame(animate);
    })();
  </script>
</Layout>

