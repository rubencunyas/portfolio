  <script is:inline>
    const revealItems = document.querySelectorAll('[data-reveal]');
    revealItems.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${Math.min(index % 6, 5) * 55}ms`);
    });
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });
      revealItems.forEach((item) => observer.observe(item));
    }
  </script>
  <script is:inline>
    const servicesForm = document.getElementById('services-form');
    const servicesSubmit = document.getElementById('services-submit');
    const servicesSubmitText = document.getElementById('services-submit-text');
    const servicesError = document.getElementById('services-error');

    const notifyLeadEmail = async (form) => {
      try {
        await fetch('/.netlify/functions/lead-email', {
          method: 'POST',
          body: new FormData(form)
        });
      } catch {
        // Netlify Forms already captured the lead; email is a secondary alert.
      }
    };

    servicesForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      servicesError.classList.add('hidden');
      servicesSubmitText.textContent = 'Enviando...';
      servicesSubmit.disabled = true;
      servicesSubmit.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(servicesForm)).toString()
        });

        if (!response.ok) {
          throw new Error('No se pudo enviar el formulario.');
        }

        await notifyLeadEmail(servicesForm);
        window.location.href = '/gracias/';
      } catch {
        servicesSubmitText.textContent = 'Intentar de nuevo';
        servicesError.classList.remove('hidden');
        servicesSubmit.disabled = false;
        servicesSubmit.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  </script>
  <script is:inline>
    (function cursorHalo() {
      const hero = document.getElementById('services-hero');
      if (!hero) return;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      let rafId = 0;
      let targetX = 0.5;
      let targetY = 0.4;
      let currentX = 0.5;
      let currentY = 0.4;

      const onPointerMove = (e) => {
        targetX = e.clientX / window.innerWidth;
        targetY = e.clientY / window.innerHeight;
      };

      const animate = () => {
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;
        hero.style.setProperty('--mxp', (100 * currentX).toFixed(2) + '%');
        hero.style.setProperty('--myp', (100 * currentY).toFixed(2) + '%');
        rafId = requestAnimationFrame(animate);
      };

      window.addEventListener('pointermove', onPointerMove, { passive: true });
      rafId = requestAnimationFrame(animate);
    })();
  </script>
  <script is:inline>
    (function phoneSwipe() {
      const carousel = document.getElementById('hpCarousel');
      if (!carousel) return;
      const dots = document.querySelectorAll('.hp-dot');
      if (!dots.length) return;

      let current = 0;
      const total = dots.length;
      let interval;

      const goTo = (index) => {
        current = ((index % total) + total) % total;
        carousel.scrollTo({ left: current * carousel.clientWidth, behavior: 'smooth' });
        dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
      };

      const next = () => goTo(current + 1);

      interval = setInterval(next, 4000);

      carousel.addEventListener('scroll', () => {
        const idx = Math.round(carousel.scrollLeft / carousel.clientWidth);
        if (idx !== current) {
          current = idx;
          dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
          clearInterval(interval);
          interval = setInterval(next, 4000);
        }
      }, { passive: true });
    })();
  </script>
