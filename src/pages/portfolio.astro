---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getProjectImages } from '@/utils/images';

const projects = await getCollection('projects');
const sorted = [...projects].sort((a, b) => {
  const aFeatured = a.data.featured ? 1 : 0;
  const bFeatured = b.data.featured ? 1 : 0;
  if (aFeatured !== bFeatured) return bFeatured - aFeatured;
  return a.data.order - b.data.order;
});

const categories = [
  { id: 'all', label: 'Todos' },
  { id: 'branding', label: 'Branding' },
  { id: 'web', label: 'Web' },
  { id: 'multimedia', label: 'Multimedia' }
];
---

<Layout
  title="Portfolio | Rubén Cunyas"
  description="Todos los proyectos de diseño digital, branding y desarrollo web."
  imageAlt="Portfolio de proyectos de diseño digital, branding y desarrollo web de Rubén Cunyas"
  keywords="portfolio diseño digital, proyectos branding, desarrollo web, diseño UX/UI, Rubén Cunyas"
>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Portfolio de proyectos digitales",
      "description": "Todos los proyectos de diseño digital, branding y desarrollo web.",
      "url": "https://portfolio-rub.netlify.app/portfolio/",
      "about": {
        "@type": "Thing",
        "name": "Proyectos de diseño y desarrollo digital"
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Portfolio", "item": "https://portfolio-rub.netlify.app/" },
        { "@type": "ListItem", "position": 2, "name": "Proyectos", "item": "https://portfolio-rub.netlify.app/portfolio/" }
      ]
    }
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Proyectos de diseño digital y desarrollo web",
    "numberOfItems": sorted.length,
    "itemListElement": sorted.map((project, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": project.data.title,
      "url": `https://portfolio-rub.netlify.app/projects/${project.slug}`
    }))
  })} />
  <main id="main-content" class="min-h-screen bg-light text-ink">
    <section class="pt-10 lg:pt-16 pb-24 lg:pb-32 px-6 lg:px-12 border-b border-ink/10">
      <div class="max-w-7xl mx-auto">
        <header class="mb-16">
          <h1 class="font-display font-bold text-5xl sm:text-7xl lg:text-8xl tracking-tight leading-none mb-6 flex items-center gap-4">
            <img src="/logo.svg" alt="Rubén Cunyas" width="48" height="48" class="w-10 h-10 sm:w-12 sm:h-12" />
            PORTAFOLIO.
          </h1>
          <p class="text-lg sm:text-xl text-ink/60 max-w-xl">
            Cada proyecto busca conectar la información de forma humana y clara.
          </p>
        </header>

        <div class="flex flex-nowrap lg:flex-wrap gap-2 lg:gap-3 overflow-x-auto mb-12 pb-1" id="project-filters">
          {categories.map((cat, i) => (
            <button
              data-filter={cat.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
              class={`filter-btn shrink-0 px-3 lg:px-5 py-1.5 lg:py-2 text-xs lg:text-sm font-medium uppercase tracking-wider transition-all duration-300 active:scale-95 ${
                i === 0
                  ? 'bg-ink text-light'
                  : 'bg-transparent text-ink/60 border border-ink/20 hover:border-ink/50 hover:text-ink'
              }`}
            >
              {cat.label}
            </button>
          ))}
        </div>

        <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {sorted.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              data-category={project.data.category}
              class="project-card group block rounded-lg border border-transparent hover:border-ink/10 hover:bg-white hover:shadow-md transition duration-500 ease-out"
            >
              <div class="relative overflow-hidden bg-black/5 aspect-video">
                <img
                  src={getProjectImages(project.slug).cover ?? project.data.cover}
                  alt={project.data.title}
                  width="900"
                  height="675"
                  loading="lazy"
                  class="w-full h-full object-cover transition duration-700 ease-out group-hover:scale-[1.03]"
                />
              </div>
              <div class="px-3 pt-3 pb-3.5">
                <h3 class="font-display font-bold text-lg sm:text-xl tracking-tight leading-tight group-hover:text-accent-blue transition-colors duration-300 mb-1.5">
                  {project.data.title}
                </h3>
                <p class="text-sm text-ink/50 leading-snug">
                  {project.data.tags.slice(0, 2).join(' · ')}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  function initFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        buttons.forEach(b => {
          b.classList.remove('bg-ink', 'text-light');
          b.classList.add('bg-transparent', 'text-ink/60', 'border', 'border-ink/20');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('bg-ink', 'text-light');
        btn.classList.remove('bg-transparent', 'text-ink/60', 'border', 'border-ink/20');
        btn.setAttribute('aria-pressed', 'true');

        cards.forEach(card => {
          const cat = card.dataset.category;
          if (filter === 'all' || cat === filter) {
            card.style.display = 'block';
            card.style.animation = 'fadeIn 0.3s ease-out';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  }

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card {
      animation: none !important;
    }
  }
</style>
