---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getProjectImages } from '@/utils/images';
import sharp from 'sharp';
import path from 'path';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const detected = getProjectImages(project.slug);
const cover = project.data.cover || detected.cover || '';
const gallery = project.data.gallery?.length ? project.data.gallery : detected.gallery;
const gallerySlider = project.data.gallery_slider?.length ? project.data.gallery_slider : detected.gallerySlider;

async function classifyGallery(urls: string[]): Promise<{ masonry: string[]; wide: string[] }> {
  const masonry: string[] = [];
  const wide: string[] = [];
  for (const url of urls) {
    try {
      const filePath = path.join(process.cwd(), 'public', url);
      const { width } = await sharp(filePath).metadata();
      (width && width >= 1920 ? wide : masonry).push(url);
    } catch {
      masonry.push(url);
    }
  }
  return { masonry, wide };
}

const { masonry: galleryMasonry, wide: galleryWide } = await classifyGallery(gallery);

const categoryLabel = project.data.category === 'branding' ? 'Branding' : project.data.category === 'web' ? 'Web' : 'Multimedia';
const pageTitle = `${project.data.title} — ${categoryLabel} | Rubén Cunyas`;
const pageDescription = project.data.result ? project.data.result.slice(0, 155) : project.data.challenge.slice(0, 155);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `¿Qué proyecto de ${categoryLabel.toLowerCase()} realizaste para ${project.data.client}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": project.data.solution.slice(0, 300)
      }
    },
    {
      "@type": "Question",
      "name": `¿Cuáles fueron los resultados del proyecto ${project.data.title}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": project.data.result.slice(0, 300)
      }
    }
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  imageAlt={`Vista previa del proyecto ${project.data.title} — ${categoryLabel} para ${project.data.client}`}
  keywords={`${project.data.title}, ${project.data.client}, ${categoryLabel.toLowerCase()}, ${project.data.tags.join(', ')}, Rubén Cunyas`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Portfolio", "item": "https://portfolio-rub.netlify.app/" },
      { "@type": "ListItem", "position": 2, "name": "Proyectos", "item": "https://portfolio-rub.netlify.app/portfolio/" },
      { "@type": "ListItem", "position": 3, "name": project.data.title, "item": `https://portfolio-rub.netlify.app/projects/${project.slug}` }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": project.data.title,
    "description": project.data.challenge.slice(0, 160),
    "url": `https://portfolio-rub.netlify.app/projects/${project.slug}`,
    "image": cover ? `https://portfolio-rub.netlify.app${cover}` : undefined,
    "author": { "@type": "Person", "name": "Rubén Cunyas" },
    "about": project.data.tags.join(', '),
    "keywords": project.data.tags,
    "inLanguage": "es-PE",
    "dateCreated": `${project.data.year}-01-01`,
    ...(project.data.client ? { "publisher": { "@type": "Organization", "name": project.data.client } } : {}),
    ...(project.data.url ? { "sameAs": project.data.url } : {})
  })} />
  <nav class="sticky top-0 z-50 bg-light/90 backdrop-blur-md border-b border-ink/10">
    <div class="flex items-center gap-3 px-6 lg:px-12 py-3">
      <a href="/" class="shrink-0">
        <img src="/logo.svg" alt="Rubén Cunyas" width="32" height="32" class="w-8 h-8" />
      </a>
      <div class="flex items-center gap-2 text-xs text-ink/40 uppercase tracking-wider">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span>/</span>
        <a href="/portfolio" class="hover:text-ink transition-colors" id="breadcrumb-portfolio">Portfolio</a>
        <span>/</span>
        <span class="text-ink/60 truncate max-w-[200px]">{project.data.title}</span>
      </div>
    </div>
  </nav>
  <main id="main-content" class="min-h-screen bg-light text-ink">
    <article>

      {cover && (
        <section class="overflow-hidden project-cover-wrap">
          <div class="cursor-pointer lightbox-trigger">
            <img
              src={cover}
              alt={`${project.data.title} - Portada`}
              class="project-cover-img w-full max-h-[50vh] object-cover"
              loading="eager"
            />
          </div>
        </section>
      )}

      <section class="py-8 lg:py-10 px-6 lg:px-12 bg-dark text-light mb-6 lg:mb-10 project-info-section">
        <div class="max-w-7xl mx-auto">
          <div class="mb-6 lg:mb-8">
            <p class="text-xs text-light/50 uppercase tracking-wider mb-2 reveal-item" data-reveal>
              {project.data.client} — {project.data.year}
            </p>
            <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl tracking-tight leading-none mb-4 text-accent-blue reveal-title" data-reveal-title>
              {project.data.title}
            </h1>
            <div class="flex flex-wrap items-center gap-3 reveal-item" data-reveal data-delay="200">
              {project.data.url && (
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-accent-orange hover:text-white active:text-white/70 transition-colors duration-300"
                >
                  VISITAR SITIO
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-[10px] uppercase tracking-wider border border-light/20 text-light/60">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <div class="grid lg:grid-cols-3 gap-6 lg:gap-10 border-t border-light/10 pt-6 lg:pt-8">
            <div class="reveal-item" data-reveal data-delay="100">
              <h2 class="text-[10px] font-semibold uppercase tracking-widest text-light/40 mb-3">
                01 — Reto
              </h2>
              <p class="text-sm lg:text-base text-light/70 leading-relaxed">
                {project.data.challenge}
              </p>
            </div>
            <div class="reveal-item" data-reveal data-delay="250">
              <h2 class="text-[10px] font-semibold uppercase tracking-widest text-light/40 mb-3">
                02 — Solución
              </h2>
              <p class="text-sm lg:text-base text-light/70 leading-relaxed">
                {project.data.solution}
              </p>
            </div>
            <div class="reveal-item" data-reveal data-delay="400">
              <h2 class="text-[10px] font-semibold uppercase tracking-widest text-light/40 mb-3">
                03 — Resultado
              </h2>
              <p class="text-sm lg:text-base text-light/70 leading-relaxed">
                {project.data.result}
              </p>
            </div>
          </div>
        </div>
      </section>

      {gallerySlider.length > 0 && (
        <section class="mt-6 lg:mt-10 pb-10 reveal-section" data-reveal>
          <div class="max-w-7xl mx-auto">
            <div class="swiper project-swiper">
              <div class="swiper-wrapper">
                {gallerySlider.map((image, index) => (
                  <div class="swiper-slide cursor-pointer lightbox-trigger">
                    <figure class="relative overflow-hidden bg-black/5 aspect-video">
                      <img
                        src={image}
                        alt={`${project.data.title} - slider ${index + 1}`}
                        class="w-full h-full object-contain"
                        loading="lazy"
                      />
                    </figure>
                  </div>
                ))}
              </div>
              <div class="swiper-pagination"></div>
            </div>
          </div>
        </section>
      )}

      {galleryWide.length > 0 && (
        <section class="mt-6 lg:mt-10">
          <div class="max-w-7xl mx-auto space-y-6 lg:space-y-10">
            {galleryWide.map((image, index) => (
              <figure class="m-0 cursor-pointer lightbox-trigger reveal-item" data-reveal data-delay={String(index * 120)}>
                <div class="overflow-hidden">
                  <img
                    src={image}
                    alt={`${project.data.title} - ${index + 1}`}
                    class="w-full h-auto reveal-img"
                    loading="lazy"
                  />
                </div>
              </figure>
            ))}
          </div>
        </section>
      )}

      {galleryMasonry.length > 0 && (
        <section class="mt-6 lg:mt-10 reveal-section" data-reveal>
          <div class="max-w-7xl mx-auto">
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
              {galleryMasonry.map((image, index) => (
                <figure class="group relative overflow-hidden break-inside-avoid cursor-pointer lightbox-trigger reveal-item" data-reveal data-delay={String(index * 100)}>
                  <img
                    src={image}
                    alt={`${project.data.title} - ${index + 1}`}
                    class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </figure>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="py-8 px-6 lg:px-12 border-b border-ink/10 reveal-item" data-reveal>
        <div class="max-w-7xl mx-auto">
          <h2 class="text-[10px] font-semibold uppercase tracking-widest text-ink/30 mb-4">
            Tecnologías
          </h2>
          <div class="flex flex-wrap gap-2">
            {project.data.technologies.map((tech) => (
              <span class="px-2.5 py-1 text-[10px] uppercase tracking-wider border border-ink/20 text-ink/60">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </section>

      <section class="py-14 lg:py-16 px-6 lg:px-12 border-b border-ink/10 reveal-item" data-reveal>
        <div class="max-w-7xl mx-auto">
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>
        </div>
      </section>

      <section class="py-12 px-6 lg:px-12 bg-ink text-light reveal-item" data-reveal>
        <div class="max-w-7xl mx-auto text-center">
          <p class="font-display font-bold text-xl sm:text-2xl mb-4">
            ¿Interesado en un proyecto similar?
          </p>
          <a
            href="/#contact"
            class="inline-flex items-center justify-center px-6 py-3 bg-light text-ink font-semibold text-sm hover:bg-accent-blue hover:text-light hover:shadow-lg hover:shadow-accent-blue/20 active:scale-95 transition-all duration-300 ease-out"
          >
            HABLEMOS
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </section>
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div id="global-lightbox" class="fixed inset-0 z-50 bg-black/95 flex items-center justify-center cursor-zoom-out opacity-0 pointer-events-none transition-opacity duration-300">
    <button class="absolute top-6 right-6 text-white/80 hover:text-white active:text-white/50 z-10 transition-colors" id="lightbox-close" aria-label="Cerrar">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img id="lightbox-image" class="max-w-[95vw] max-h-[95vh] object-contain" src="" alt="" />
  </div>
</Layout>

<style is:global>
  @import 'swiper/swiper-bundle.css';

  .project-swiper .swiper-pagination {
    position: relative;
    margin-top: 1.5rem;
    bottom: auto;
  }

  .project-swiper .swiper-pagination-bullet {
    @apply bg-accent-blue/30;
    opacity: 1;
    width: 10px;
    height: 10px;
  }

  .project-swiper .swiper-pagination-bullet-active {
    @apply bg-accent-blue;
  }

  .project-cover-wrap {
    clip-path: inset(0 0 0 0);
  }

  .project-cover-img {
    transform: scale(1.08);
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-cover-img.cover-revealed {
    transform: scale(1);
  }

  .reveal-title .title-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px) rotateX(-40deg);
    animation: charReveal 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .reveal-item {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-item.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-section.is-revealed .reveal-item {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-img {
    transform: scale(1.06);
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-item.is-revealed .reveal-img {
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item,
    .reveal-title .title-char,
    .project-cover-img {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
      transition: none !important;
    }
  }

  @keyframes charReveal {
    0% {
      opacity: 0;
      transform: translateY(28px) rotateX(-40deg);
    }
    100% {
      opacity: 1;
      transform: translateY(0) rotateX(0);
    }
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination } from 'swiper/modules';

  function initBreadcrumb() {
    const portfolioLink = document.getElementById('breadcrumb-portfolio');
    if (portfolioLink) {
      const ref = document.referrer;
      if (ref && (ref.includes('/portfolio') || ref.includes('/projects/'))) {
        portfolioLink.href = '/portfolio';
      }
    }
  }

  function initProjectSwiper() {
    const swiperEl = document.querySelector('.project-swiper');
    if (!swiperEl) return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    new Swiper('.project-swiper', {
      modules: [Autoplay, Pagination],
      slidesPerView: 1,
      spaceBetween: 0,
      loop: true,
      autoplay: prefersReduced ? false : {
        delay: 5000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
    });
  }

  function initLightbox() {
    const overlay = document.getElementById('global-lightbox');
    const lightboxImg = document.getElementById('lightbox-image');
    const closeBtn = document.getElementById('lightbox-close');
    if (!overlay || !lightboxImg || !closeBtn) return;

    function open(src, alt) {
      lightboxImg.src = src;
      lightboxImg.alt = alt || '';
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        const img = el.querySelector('img');
        if (img) open(img.src, img.alt);
      });
    });

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }

  function initCoverReveal() {
    const coverImg = document.querySelector('.project-cover-img');
    if (!coverImg) return;
    if (coverImg.complete) {
      coverImg.classList.add('cover-revealed');
    } else {
      coverImg.addEventListener('load', () => coverImg.classList.add('cover-revealed'));
    }
  }

  function initTitleChars() {
    const titleEl = document.querySelector('.reveal-title');
    if (!titleEl) return;
    const text = titleEl.textContent || '';
    titleEl.textContent = '';
    const chars = [...text];
    chars.forEach((char, i) => {
      const span = document.createElement('span');
      span.className = 'title-char';
      span.textContent = char === ' ' ? '\u00A0' : char;
      span.style.animationDelay = `${i * 35}ms`;
      titleEl.appendChild(span);
    });
  }

  function initScrollReveal() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      document.querySelectorAll('.reveal-item, .reveal-section').forEach(el => {
        el.classList.add('is-revealed');
      });
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          if (el.hasAttribute('data-delay')) {
            setTimeout(() => el.classList.add('is-revealed'), parseInt(el.getAttribute('data-delay') || '0'));
          } else {
            el.classList.add('is-revealed');
          }
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal-item, .reveal-section').forEach(el => observer.observe(el));
  }

  initBreadcrumb();
  initCoverReveal();
  initTitleChars();
  initScrollReveal();
  initLightbox();
  initProjectSwiper();
  document.addEventListener('astro:after-swap', () => {
    initBreadcrumb();
    initCoverReveal();
    initTitleChars();
    initScrollReveal();
    initLightbox();
    initProjectSwiper();
  });
</script>
