---
import Layout from '../layouts/Layout.astro';

const whatsappNumber = "51987518768";

const projectTypes = [
  { value: "branding", label: "Branding / Identidad visual" },
  { value: "web", label: "Diseño y desarrollo web" },
  { value: "multimedia", label: "Contenido multimedia" },
  { value: "unknown", label: "Aún no lo sé / Varios" }
];

const baseSections = [
  {
    number: "01",
    title: "Tus datos",
    fields: [
      { id: "sender-name", label: "Tu nombre", type: "text", placeholder: "¿Cómo te llamas?" },
      { id: "sender-email", label: "Tu email", type: "email", placeholder: "tu@email.com" },
      { id: "sender-phone", label: "Tu teléfono / WhatsApp", type: "text", placeholder: "Ej. +51 999 888 777" }
    ]
  },
  {
    number: "02",
    title: "Tipo de proyecto",
    fields: []
  },
  {
    number: "03",
    title: "Sobre la marca / empresa",
    fields: [
      { id: "brand-name", label: "Nombre de tu marca", type: "text", placeholder: "Ej. Tu marca o nombre de proyecto..." },
      { id: "brand-dedication", label: "¿A qué se dedican?", type: "textarea", placeholder: "Cuéntame en un par de líneas a qué se dedica tu marca o empresa..." },
      { id: "brand-social", label: "Web o redes sociales actuales", type: "text", placeholder: "Ej. instagram.com/tumarca, tumarca.com" }
    ]
  },
  {
    number: "04",
    title: "Detalles del proyecto",
    fields: []
  },
  {
    number: "05",
    title: "Tu público",
    fields: [
      { id: "audience", label: "¿Quién es tu cliente ideal?", type: "textarea", placeholder: "A quién le hablamos: edades, intereses, ubicación..." }
    ]
  },
  {
    number: "06",
    title: "Competencia y referencias",
    fields: [
      { id: "competitors", label: "¿Quiénes son tus principales competidores?", type: "textarea", placeholder: "Nombres o links de la competencia directa..." },
      { id: "references", label: "¿Hay marcas o proyectos que te sirvan de inspiración?", type: "textarea", placeholder: "Puedes dejar links aquí..." },
      { id: "referral", label: "¿Cómo nos conociste?", type: "text", placeholder: "Ej. Instagram, Google, recomendación..." }
    ]
  },
  {
    number: "07",
    title: "Tiempos y presupuesto",
    fields: [
      { id: "deadline", label: "¿Para qué fecha te gustaría tener esto listo?", type: "text", placeholder: "Ej. En 2 semanas, para diciembre 2026..." },
      { id: "budget", label: "¿Cuál es tu presupuesto estimado?", type: "text", placeholder: "Ej. $500–$1500, $3000+, aún no lo sé..." },
      { id: "formats", label: "¿Necesitas algún formato en específico?", type: "textarea", placeholder: "Ej. Archivos para imprenta, código funcionando, plantillas editables..." }
    ]
  }
];

const typeConditionalFields = {
  branding: [
    { id: "b-logo", label: "¿Tienes un logotipo actual o empezamos de cero?", type: "text", placeholder: "Ej. Tenemos algo, pero queremos renovarlo..." },
    { id: "b-scope", label: "¿Necesitas manual de marca completo o solo identidad básica?", type: "text", placeholder: "Ej. Solo logo y colores / Manual completo con aplicaciones..." },
    { id: "b-apply", label: "¿Dónde se va a aplicar la marca?", type: "textarea", placeholder: "Ej. Redes sociales, web, papelería, empaques, local físico..." },
    { id: "b-style", label: "Colores, tipografías o estilos que te gusten (o que NO te gusten)", type: "textarea", placeholder: "Puedes dejar referencias o describirlo..." }
  ],
  web: [
    { id: "w-pages", label: "¿Cuántas secciones o páginas necesitas?", type: "text", placeholder: "Ej. Landing de 1 página / 5 secciones / Blog completo..." },
    { id: "w-store", label: "¿Necesitas tienda online?", type: "text", placeholder: "Ej. No / Sí, con 10 productos / Sí, catálogo grande..." },
    { id: "w-content", label: "¿Tienes contenido listo (textos, imágenes) o necesitas que lo creemos?", type: "text", placeholder: "Ej. Tengo textos e imágenes / Necesito todo..." },
    { id: "w-integrations", label: "¿Integraciones necesarias?", type: "textarea", placeholder: "Ej. Pasarela de pagos, WhatsApp, CRM, newsletter..." }
  ],
  multimedia: [
    { id: "m-type", label: "¿Qué tipo de contenido necesitas?", type: "text", placeholder: "Ej. Video corporativo, reel para redes, motion graphics..." },
    { id: "m-duration", label: "Duración estimada", type: "text", placeholder: "Ej. 30 segundos, 2 minutos, no lo sé aún..." },
    { id: "m-material", label: "¿Tienes material base?", type: "textarea", placeholder: "Ej. Tengo guión, imágenes y audio / Solo la idea..." },
    { id: "m-platform", label: "¿Para qué plataforma?", type: "text", placeholder: "Ej. Instagram y TikTok / Web corporativa / YouTube..." }
  ],
  unknown: [
    { id: "u-idea", label: "Cuéntame más sobre tu idea", type: "textarea", placeholder: "¿En qué estás pensando? Cuéntame lo que sea que tengas en mente, aunque sea una idea vaga..." }
  ]
};

const totalSections = baseSections.length;
---

<Layout
  title="Brief para proyectos digitales | Rubén Cunyas"
  description="Cuéntame sobre tu proyecto de web, landing page o branding y recibe una cotización personalizada en 24 horas."
>
  <main id="main-content">
    <section class="relative py-10 lg:py-14 px-6 lg:px-12 border-b border-ink/10 bg-light text-ink">
      <div class="max-w-3xl mx-auto text-center">
        <span class="text-sm font-medium tracking-widest text-accent-blue uppercase mb-4 block">Brief</span>
        <h1 class="font-display font-bold text-5xl sm:text-7xl lg:text-8xl tracking-tight leading-none mb-6">
          CUÉNTAME<br/>
          <span class="text-accent-orange">TU IDEA.</span>
        </h1>
        <p class="text-xl text-ink/70 max-w-2xl mx-auto">
          Responde por pasos. Al final revisamos todo antes de enviar.
        </p>
      </div>
    </section>

    <section class="py-24 lg:py-32 px-6 lg:px-12 bg-dark text-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12" id="step-indicator">
          <span class="text-sm text-white/40 uppercase tracking-wider" id="step-label">Paso 1 de 7</span>
          <div class="mt-3 w-full bg-white/10 h-1 max-w-xs mx-auto rounded-full overflow-hidden">
            <div class="bg-accent-blue h-full rounded-full transition-all duration-300" id="step-progress" style="width: 14%"></div>
          </div>
        </div>

        <form id="brief-form" class="space-y-16">
          {baseSections.map((section, i) => (
            <div class="step-content" data-step={i + 1} style={`display: ${i === 0 ? 'block' : 'none'}`}>
              <fieldset>
                <legend class="flex items-start gap-4 mb-8">
                  <span class="font-display font-bold text-4xl sm:text-5xl text-accent-blue/30">{section.number}</span>
                  <span class="font-display font-bold text-2xl sm:text-3xl text-white">{section.title}</span>
                </legend>
                <div class="space-y-6">
                  {section.fields.map((field) => (
                    <div>
                      <label for={field.id} class="block text-sm text-white/60 uppercase tracking-wider mb-2">
                        {field.label}
                      </label>
                      {field.type === "textarea" ? (
                        <textarea
                          id={field.id}
                          name={field.id}
                          rows="4"
                          required={section.number === "01"}
                          class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent-blue focus:outline-none transition-colors duration-300 resize-none"
                          placeholder={field.placeholder}
                        ></textarea>
                      ) : (
                        <input
                          type={field.type}
                          id={field.id}
                          name={field.id}
                          required={section.number === "01"}
                          class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent-blue focus:outline-none transition-colors duration-300"
                          placeholder={field.placeholder}
                        />
                      )}
                    </div>
                  ))}
                  {section.title === "Tipo de proyecto" && (
                    <div class="grid gap-3" id="project-type-options">
                      {projectTypes.map((t, idx) => (
                        <label data-action="select-type" class={`flex items-center gap-4 p-4 border cursor-pointer transition-all duration-300 ${
                          idx === 0 ? 'border-accent-blue bg-accent-blue/10' : 'border-white/10 hover:border-white/30 bg-white/5'
                        }`} data-value={t.value}>
                          <input type="radio" name="project-type" value={t.value} class="sr-only" checked={idx === 0} />
                          <span class={`w-5 h-5 rounded-full border-2 flex items-center justify-center ${
                            idx === 0 ? 'border-accent-blue' : 'border-white/30'
                          }`}>
                            {idx === 0 && <span class="w-2.5 h-2.5 rounded-full bg-accent-blue"></span>}
                          </span>
                          <span class="font-semibold text-white">{t.label}</span>
                        </label>
                      ))}
                    </div>
                  )}
                  {section.title === "Detalles del proyecto" && (
                    <div id="conditional-fields">
                      {Object.entries(typeConditionalFields).map(([type, fields]) => (
                        <div class="conditional-block space-y-6" data-type={type} style={`display: ${type === 'branding' ? 'block' : 'none'}`}>
                          {fields.map((field) => (
                            <div>
                              <label for={field.id} class="block text-sm text-white/60 uppercase tracking-wider mb-2">
                                {field.label}
                              </label>
                              {field.type === "textarea" ? (
                                <textarea
                                  id={field.id}
                                  name={field.id}
                                  rows="4"
                                  class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent-blue focus:outline-none transition-colors duration-300 resize-none"
                                  placeholder={field.placeholder}
                                ></textarea>
                              ) : (
                                <input
                                  type="text"
                                  id={field.id}
                                  name={field.id}
                                  class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent-blue focus:outline-none transition-colors duration-300"
                                  placeholder={field.placeholder}
                                />
                              )}
                            </div>
                          ))}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </fieldset>
              <div class="flex justify-between mt-10">
                <button type="button" data-action="prev" class="px-6 py-3 border border-white/20 text-white/60 hover:text-white hover:border-white/50 active:scale-95 transition-all duration-300 text-sm font-semibold uppercase tracking-wider" style={`visibility: ${i === 0 ? 'hidden' : 'visible'}`}>
                  ANTERIOR
                </button>
                <button type="button" data-action="next" class="px-8 py-3 bg-accent-blue text-dark font-semibold hover:bg-white active:scale-95 active:brightness-90 transition-all duration-300 text-sm uppercase tracking-wider ml-auto">
                  SIGUIENTE
                </button>
              </div>
            </div>
          ))}

          <div class="step-content" data-step={totalSections + 1} style="display: none">
            <div class="text-center mb-12">
              <span class="font-display font-bold text-4xl sm:text-5xl text-accent-blue/30 block mb-4">✓</span>
              <h3 class="font-display font-bold text-2xl sm:text-3xl text-white mb-4">Revisa tu brief</h3>
              <p class="text-white/60">Verifica que todo esté correcto antes de enviar</p>
            </div>
            <div class="space-y-8 mb-10" id="summary-container"></div>
            <div class="flex justify-between mt-10">
              <button type="button" data-action="prev" class="px-6 py-3 border border-white/20 text-white/60 hover:text-white hover:border-white/50 active:scale-95 transition-all duration-300 text-sm font-semibold uppercase tracking-wider">ANTERIOR</button>
              <button type="submit" id="brief-submit-btn" class="px-10 py-4 bg-accent-blue text-dark font-semibold text-lg hover:bg-white active:scale-95 active:brightness-90 transition-all duration-300 flex items-center justify-center gap-3">
                <span id="brief-btn-text">ENVIAR BRIEF</span>
                <svg id="brief-btn-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </button>
            </div>
            <p class="mt-8 text-sm text-white/40 text-center">
              Recibirás una copia del brief por WhatsApp y yo lo recibiré en mi correo. En cuanto lo revise, coordinamos una reunión.
            </p>
          </div>
        </form>
      </div>
    </section>
  </main>
  <script is:inline>
    const form = document.getElementById('brief-form');
    const stepContents = document.querySelectorAll('.step-content');
    const stepLabel = document.getElementById('step-label');
    const stepProgress = document.getElementById('step-progress');
    const typeRadios = document.querySelectorAll('input[name="project-type"]');
    const conditionalBlocks = document.querySelectorAll('.conditional-block');
    const totalSteps = stepContents.length;
    let currentStep = 1;

    function getSelectedType() {
      for (const radio of typeRadios) {
        if (radio.checked) return radio.value;
      }
      return 'branding';
    }

    function selectProjectType(value) {
      const labels = document.querySelectorAll('#project-type-options label');
      labels.forEach(opt => {
        const isSelected = opt.dataset.value === value;
        const radio = opt.querySelector('input[type="radio"]');
        const circle = opt.querySelector('span:first-of-type');
        const existingDot = circle.querySelector('.w-2\\.5');
        if (existingDot) existingDot.remove();
        if (isSelected) {
          opt.className = 'flex items-center gap-4 p-4 border cursor-pointer transition-all duration-300 border-accent-blue bg-accent-blue/10';
          radio.checked = true;
          circle.className = 'w-5 h-5 rounded-full border-2 flex items-center justify-center border-accent-blue';
          const dot = document.createElement('span');
          dot.className = 'w-2.5 h-2.5 rounded-full bg-accent-blue';
          circle.appendChild(dot);
        } else {
          opt.className = 'flex items-center gap-4 p-4 border cursor-pointer transition-all duration-300 border-white/10 hover:border-white/30 bg-white/5';
          radio.checked = false;
          circle.className = 'w-5 h-5 rounded-full border-2 flex items-center justify-center border-white/30';
        }
      });
      conditionalBlocks.forEach(block => {
        block.style.display = block.dataset.type === value ? 'block' : 'none';
      });
    }

    form.addEventListener('click', (e) => {
      const target = e.target.closest('[data-action]');
      if (!target) return;
      const action = target.dataset.action;

      if (action === 'next' || action === 'prev') {
        if (action === 'prev' && currentStep > 1) {
          goToStep(currentStep - 1);
          return;
        }
        if (action === 'next') {
          const currentSection = stepContents[currentStep - 1];
          const requiredFields = currentSection.querySelectorAll('[required]');
          let valid = true;
          requiredFields.forEach(f => { if (!f.value.trim()) valid = false; });
          if (!valid) {
            requiredFields.forEach(f => {
              if (!f.value.trim()) {
                f.classList.remove('border-white/10');
                f.classList.add('border-accent-orange');
                setTimeout(() => {
                  f.classList.remove('border-accent-orange');
                  f.classList.add('border-white/10');
                }, 2000);
              }
            });
            return;
          }
          if (currentStep < totalSteps) goToStep(currentStep + 1);
        }
      }

      if (action === 'select-type') {
        const value = target.dataset.value;
        selectProjectType(value);
      }
    });

    const sectionMeta = [
      { title: "TUS DATOS", ids: ["sender-name", "sender-email", "sender-phone"] },
      { title: "TIPO DE PROYECTO", ids: ["project-type"] },
      { title: "SOBRE LA MARCA / EMPRESA", ids: ["brand-name", "brand-dedication", "brand-social"] },
      { title: "DETALLES DEL PROYECTO", ids: [] },
      { title: "TU PÚBLICO", ids: ["audience"] },
      { title: "COMPETENCIA Y REFERENCIAS", ids: ["competitors", "references", "referral"] },
      { title: "TIEMPOS Y PRESUPUESTO", ids: ["deadline", "budget", "formats"] }
    ];

    const typeFieldIds = {
      branding: ["b-logo", "b-scope", "b-apply", "b-style"],
      web: ["w-pages", "w-store", "w-content", "w-integrations"],
      multimedia: ["m-type", "m-duration", "m-material", "m-platform"],
      unknown: ["u-idea"]
    };

    function buildWhatsAppMessage() {
      const fd = new FormData(form);
      const type = getSelectedType();
      const typeLabelMap = { branding: "Branding / Identidad visual", web: "Diseño y desarrollo web", multimedia: "Contenido multimedia", unknown: "Aún no lo sé / Varios" };
      const enhancedMeta = sectionMeta.map(s => {
        if (s.title === "TIPO DE PROYECTO") return { ...s, ids: ["project-type"] };
        if (s.title === "DETALLES DEL PROYECTO") return { ...s, ids: typeFieldIds[type] || [] };
        return s;
      });
      let message = "¡Hola! Te envío mi brief completo:%0A%0A";
      enhancedMeta.forEach((section) => {
        message += `━━━ ${section.title} ━━━%0A`;
        if (section.title === "TIPO DE PROYECTO") {
          message += `${typeLabelMap[type] || type}%0A`;
        } else {
          section.ids.forEach(id => {
            const value = fd.get(id) || "";
            message += `${value}%0A`;
          });
        }
        message += `%0A`;
      });
      message += "━ Espero tu respuesta para coordinar. ¡Gracias!";
      return message;
    }

    function buildEmailBody() {
      const fd = new FormData(form);
      const type = getSelectedType();
      const typeLabelMap = { branding: "Branding / Identidad visual", web: "Diseño y desarrollo web", multimedia: "Contenido multimedia", unknown: "Aún no lo sé / Varios" };
      const enhancedMeta = sectionMeta.map(s => {
        if (s.title === "TIPO DE PROYECTO") return { ...s, ids: ["project-type"] };
        if (s.title === "DETALLES DEL PROYECTO") return { ...s, ids: typeFieldIds[type] || [] };
        return s;
      });
      const labelMap = {
        "sender-name": "Nombre", "sender-email": "Email", "sender-phone": "Teléfono",
        "project-type": "Tipo de proyecto",
        "brand-name": "Nombre de tu marca", "brand-dedication": "¿A qué se dedican?", "brand-social": "Web o redes",
        "b-logo": "¿Logo actual o desde cero?", "b-scope": "Alcance del branding", "b-apply": "Aplicaciones", "b-style": "Preferencias de estilo",
        "w-pages": "Secciones/páginas", "w-store": "¿Tienda online?", "w-content": "Contenido", "w-integrations": "Integraciones",
        "m-type": "Tipo de contenido", "m-duration": "Duración", "m-material": "Material base", "m-platform": "Plataforma",
        "u-idea": "Su idea",
        "audience": "Cliente ideal",
        "competitors": "Competidores", "references": "Inspiración", "referral": "¿Cómo nos conociste?",
        "deadline": "Fecha límite", "budget": "Presupuesto estimado", "formats": "Formatos"
      };
      let body = "";
      enhancedMeta.forEach((section) => {
        body += `${section.title}\n`;
        if (section.title === "TIPO DE PROYECTO") {
          body += `Tipo de proyecto: ${typeLabelMap[type] || type}\n`;
        } else {
          section.ids.forEach(id => {
            const value = fd.get(id) || "";
            body += `${labelMap[id] || id}: ${value}\n`;
          });
        }
        body += "\n";
      });
      return body;
    }

    function buildSummaryHTML() {
      const fd = new FormData(form);
      const type = getSelectedType();
      const typeLabelMap = { branding: "Branding / Identidad visual", web: "Diseño y desarrollo web", multimedia: "Contenido multimedia", unknown: "Aún no lo sé / Varios" };
      const enhancedMeta = sectionMeta.map(s => {
        if (s.title === "TIPO DE PROYECTO") return { ...s, ids: ["project-type"] };
        if (s.title === "DETALLES DEL PROYECTO") return { ...s, ids: typeFieldIds[type] || [] };
        return s;
      });
      const labelMap = {
        "sender-name": "Tu nombre", "sender-email": "Tu email", "sender-phone": "Tu teléfono",
        "project-type": "Tipo de proyecto",
        "brand-name": "Nombre de tu marca", "brand-dedication": "¿A qué se dedican?", "brand-social": "Web o redes",
        "b-logo": "¿Logo actual o desde cero?", "b-scope": "Alcance del branding", "b-apply": "Aplicaciones", "b-style": "Preferencias de estilo",
        "w-pages": "Secciones/páginas", "w-store": "¿Tienda online?", "w-content": "Contenido", "w-integrations": "Integraciones",
        "m-type": "Tipo de contenido", "m-duration": "Duración", "m-material": "Material base", "m-platform": "Plataforma",
        "u-idea": "Su idea",
        "audience": "Cliente ideal",
        "competitors": "Competidores", "references": "Inspiración", "referral": "¿Cómo nos conociste?",
        "deadline": "Fecha límite", "budget": "Presupuesto estimado", "formats": "Formatos"
      };
      let html = "";
      enhancedMeta.forEach((section) => {
        html += `<div class="border border-white/10 p-6"><h4 class="font-display font-bold text-lg text-accent-blue mb-4">${section.title}</h4><div class="space-y-3">`;
        if (section.title === "TIPO DE PROYECTO") {
          html += `<div><span class="text-xs text-white/40 uppercase tracking-wider block mb-1">Tipo de proyecto</span><p class="text-white">${typeLabelMap[type] || type}</p></div>`;
        } else {
          section.ids.forEach(id => {
            const value = fd.get(id) || "";
            html += `<div><span class="text-xs text-white/40 uppercase tracking-wider block mb-1">${labelMap[id] || id}</span><p class="text-white">${value || '<span class="text-white/30 italic">Sin respuesta</span>'}</p></div>`;
          });
        }
        html += `</div></div>`;
      });
      return html;
    }

    function goToStep(step) {
      currentStep = step;
      stepContents.forEach(el => el.style.display = el.dataset.step == step ? 'block' : 'none');
      stepLabel.textContent = `Paso ${Math.min(step, totalSteps - 1)} de ${totalSteps - 1}`;
      stepProgress.style.width = `${((step - 1) / (totalSteps - 1)) * 100}%`;
      if (step === totalSteps) {
        document.getElementById('summary-container').innerHTML = buildSummaryHTML();
      }
      window.scrollTo({ top: document.querySelector('.step-content').offsetTop - 40, behavior: 'smooth' });
    }

    function getFormFields() {
      const fd = new FormData(form);
      const type = getSelectedType();
      const typeLabelMap = { branding: "Branding / Identidad visual", web: "Diseño y desarrollo web", multimedia: "Contenido multimedia", unknown: "Aún no lo sé / Varios" };
      const enhancedMeta = sectionMeta.map(s => {
        if (s.title === "TIPO DE PROYECTO") return { ...s, ids: ["project-type"] };
        if (s.title === "DETALLES DEL PROYECTO") return { ...s, ids: typeFieldIds[type] || [] };
        return s;
      });
      const fieldLabelMap = {
        "sender-name": "Tu nombre", "sender-email": "Tu email", "sender-phone": "Tu teléfono / WhatsApp",
        "project-type": "Tipo de proyecto",
        "brand-name": "Nombre de tu marca", "brand-dedication": "¿A qué se dedican?", "brand-social": "Web o redes",
        "b-logo": "¿Logo actual o desde cero?", "b-scope": "Alcance del branding", "b-apply": "Aplicaciones", "b-style": "Preferencias de estilo",
