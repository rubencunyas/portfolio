    const submitBtn = document.getElementById('brief-submit-btn');
    const btnText = document.getElementById('brief-btn-text');
    const btnSpinner = document.getElementById('brief-btn-spinner');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      btnText.textContent = 'ENVIANDO...';
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      try {
        await fetch('https://formsubmit.co/ajax/ruben.cunyas.b@gmail.com', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(getFormFields())
        });
        const whatsappUrl = 'https://wa.me/51987518768?text=' + buildWhatsAppMessage();
        window.open(whatsappUrl, '_blank');
        btnText.textContent = '¡BRIEF ENVIADO!';
        submitBtn.classList.remove('bg-accent-blue');
        submitBtn.classList.add('bg-success');
        setTimeout(() => {
          form.reset();
          goToStep(1);
          btnText.textContent = 'ENVIAR BRIEF';
          btnSpinner.classList.add('hidden');
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed', 'bg-success');
          submitBtn.classList.add('bg-accent-blue');
        }, 3000);
      } catch (err) {
        btnText.textContent = 'ERROR - INTENTA DE NUEVO';
        submitBtn.classList.remove('bg-accent-blue');
        submitBtn.classList.add('bg-accent-orange');
        setTimeout(() => {
          btnText.textContent = 'ENVIAR BRIEF';
          btnSpinner.classList.add('hidden');
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed', 'bg-accent-orange');
          submitBtn.classList.add('bg-accent-blue');
