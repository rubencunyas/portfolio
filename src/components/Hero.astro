<section id="hero-section" class="relative isolate overflow-hidden border-b border-ink/10 text-ink lg:min-h-[calc(100dvh-4rem)]" style="background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(48,49,228,0.06) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 70%, rgba(254,66,1,0.04) 0%, transparent 60%), #F8F6F0;">
  <div class="hero-halo absolute inset-0 z-[1] pointer-events-none" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -left-20 top-28 h-64 w-[120%] -rotate-6 sm:h-80 z-[2]" style="background: linear-gradient(105deg, rgba(48,49,228,0.18) 0%, rgba(48,49,228,0.08) 50%, transparent 100%); backdrop-filter: blur(40px); border-bottom: 1px solid rgba(48,49,228,0.12); animation: heroBarIn 0.7s cubic-bezier(0.16,1,0.3,1) both, barFloat 8s 0.7s ease-in-out infinite;"></div>
  <div class="pointer-events-none absolute -right-12 bottom-24 h-20 w-[70%] rotate-3 z-[2]" style="background: linear-gradient(105deg, transparent 0%, rgba(254,66,1,0.10) 50%, rgba(254,66,1,0.16) 100%); backdrop-filter: blur(40px); border-bottom: 1px solid rgba(254,66,1,0.10); animation: heroBarIn 0.7s 0.15s cubic-bezier(0.16,1,0.3,1) both, barFloatOrange 9s 0.85s ease-in-out infinite;"></div>
  <div class="relative z-10 mx-auto flex max-w-7xl flex-col justify-between gap-20 px-6 py-20 lg:px-12 lg:py-24 scroll-animate">
    <p class="text-sm font-bold uppercase tracking-widest">Diseño + desarrollo digital <span class="ml-3 text-accent-orange">Lima / LATAM</span></p>
    <div class="grid gap-12 lg:grid-cols-[1.35fr_.65fr] lg:items-end">
      <h1 class="font-display text-6xl font-bold uppercase leading-[.82] tracking-[-0.03em] sm:text-8xl md:text-9xl lg:text-10xl">
        Ideas<br />con <span class="text-light" style="text-shadow: 0 0 0 2px #1A1A1A, 2px 2px 0 #1A1A1A;">forma.</span><br />Y fondo.
      </h1>
      <div class="max-w-md border-l-2 border-ink/30 pl-5 lg:mb-3">
        <p class="text-lg leading-relaxed sm:text-xl text-ink/80">Soy Rubén. Diseño marcas, productos y sitios web que hacen que los negocios se entiendan, se vean y avancen mejor.</p>
        <a href="#work" class="mt-8 inline-flex min-h-12 items-center bg-ink px-6 text-sm font-bold uppercase tracking-wider text-light transition-all duration-300 ease-enter hover:bg-accent-orange-deep hover:shadow-xl hover:shadow-accent-orange/30 active:scale-95">Ver proyectos <span class="ml-3 text-lg" aria-hidden="true">↓</span></a>
      </div>
    </div>
    <div class="flex flex-wrap gap-x-8 gap-y-3 border-t border-ink/10 pt-5 text-xs font-bold uppercase tracking-widest text-ink/50 sm:text-sm">
      <span>Branding</span><span>UX/UI</span><span>Web</span><span>Productos digitales</span><span class="text-accent-blue font-extrabold">13+ años de experiencia</span>
    </div>
  </div>
</section>

<script is:inline>
  (function cursorHalo() {
    const hero = document.getElementById('hero-section');
    if (!hero) return;
    const halo = hero.querySelector('.hero-halo');
    if (!halo) return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    let rafId = 0;
    let targetX = 0.5;
    let targetY = 0.3;
    let currentX = 0.5;
    let currentY = 0.3;

    const onPointerMove = (e) => {
      targetX = e.clientX / window.innerWidth;
      targetY = e.clientY / window.innerHeight;
    };

    const animate = () => {
      currentX += (targetX - currentX) * 0.06;
      currentY += (targetY - currentY) * 0.06;
      const xp = (100 * currentX).toFixed(2) + '%';
      const yp = (100 * currentY).toFixed(2) + '%';
      halo.style.background = `radial-gradient(320px 320px at ${xp} ${yp}, rgba(48,49,228,0.10), transparent 70%)`;
      rafId = requestAnimationFrame(animate);
    };

    window.addEventListener('pointermove', onPointerMove, { passive: true });
    rafId = requestAnimationFrame(animate);
  })();
</script>
