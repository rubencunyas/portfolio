---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: "LinkedIn", url: "https://pe.linkedin.com/in/rubencunyas", icon: "linkedin" }
];

const contactInfo = [
  { label: "Email", value: "hello@cunyas.com", href: "mailto:hello@cunyas.com" },
  { label: "Ubicación", value: "LATAM", href: "#" }
];
---

<footer id="contact" class="py-24 lg:py-32 px-6 lg:px-12 bg-white text-dark scroll-animate opacity-0 translate-y-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl tracking-tight mb-8 text-dark">
          HABLEMOS.
        </h2>
        <p class="text-xl text-dark/70 max-w-lg mb-12">
          ¿Tienes un proyecto en mente? Me encantaría escuchar tu idea y explorar cómo puedo ayudarte a hacerla realidad.
        </p>
        
        <form 
          id="contact-form"
          name="portfolio-contact"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="portfolio-contact" />
          <input type="hidden" name="subject" data-remove-prefix value="Nuevo lead desde Portfolio (%{submissionId})" />
          <p class="hidden">
            <label>No llenar: <input name="bot-field" /></label>
          </p>
          <div>
            <label for="name" class="block text-sm text-dark/50 uppercase tracking-wider mb-2">Nombre</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              autocomplete="name"
              required
              class="w-full px-4 py-3 bg-dark/5 border border-dark/20 text-dark placeholder-dark/30 focus:border-accent-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-blue focus-visible:ring-offset-2 transition-colors duration-300"
              placeholder="Tu nombre"
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm text-dark/50 uppercase tracking-wider mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              autocomplete="email"
              spellcheck="false"
              required
              class="w-full px-4 py-3 bg-dark/5 border border-dark/20 text-dark placeholder-dark/30 focus:border-accent-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-blue focus-visible:ring-offset-2 transition-colors duration-300"
              placeholder="tu@email.com"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm text-dark/50 uppercase tracking-wider mb-2">Mensaje</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4"
              required
              class="w-full px-4 py-3 bg-dark/5 border border-dark/20 text-dark placeholder-dark/30 focus:border-accent-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-blue focus-visible:ring-offset-2 transition-colors duration-300 resize-none"
              placeholder="Cuéntame sobre tu proyecto…"
            ></textarea>
          </div>
          
          <button 
            type="submit"
            id="submit-btn"
            class="w-full px-8 py-4 bg-accent-blue text-white font-semibold text-lg hover:bg-dark transition-colors duration-300 flex items-center justify-center gap-3"
          >
            <span id="btn-text">ENVIAR MENSAJE</span>
            <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
          <p class="text-sm leading-6 text-dark/50">
            Recibiré tu mensaje y te responderé por correo o WhatsApp si lo incluyes en el mensaje.
          </p>
          <p id="contact-error" class="hidden border border-accent-orange/30 bg-accent-orange/10 px-4 py-3 text-sm leading-6 text-dark">
            No pude enviar el formulario. Escríbeme a <a class="font-semibold text-accent-blue underline" href="mailto:hello@cunyas.com">hello@cunyas.com</a>.
          </p>
        </form>
      </div>
      
      <div class="flex flex-col justify-center lg:pl-16">
        <nav aria-label="Contactos">
          <ul class="space-y-6 mb-12">
            {contactInfo.map((info) => (
              <li>
                <span class="text-sm text-dark/50 uppercase tracking-wider block mb-1">{info.label}</span>
                <a 
                  href={info.href}
                  class="text-2xl lg:text-3xl font-display font-bold hover:text-accent-blue transition-colors duration-300 text-dark"
                  aria-label={`${info.label}: ${info.value}`}
                >
                  {info.value}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        
        <div>
          <span class="text-sm text-dark/50 uppercase tracking-wider block mb-4">Sígueme</span>
          <div class="flex gap-4">
            {socialLinks.map((social) => (
              <a 
                href={social.url}
                class="w-12 h-12 flex items-center justify-center border border-dark/20 hover:border-accent-blue hover:bg-accent-blue text-dark hover:text-white transition-all duration-300"
                aria-label={social.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            ))}
            <a 
              href="/CV-RubenCunyas.pdf" 
              download
              class="inline-flex h-12 items-center justify-center gap-2 border border-dark/20 px-4 text-sm font-semibold uppercase tracking-wider text-dark hover:border-accent-blue hover:bg-accent-blue hover:text-white transition-colors duration-300"
              aria-label="Descargar CV"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              CV
            </a>
          </div>
        </div>
      </div>
    </div>
    
    <div class="pt-12 mt-16 border-t border-dark/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-dark/50 text-sm">
        © {currentYear}. Todos los derechos reservados.
      </p>
      <p class="text-dark/50 text-sm">
        Diseñado y desarrollado con <span class="text-accent-orange">♥</span>
      </p>
    </div>
  </div>
</footer>

<script>
  const contactForm = document.getElementById('contact-form');
  const contactSubmit = document.getElementById('submit-btn');
  const contactText = document.getElementById('btn-text');
  const contactSpinner = document.getElementById('btn-spinner');
  const contactError = document.getElementById('contact-error');

  const notifyLeadEmail = async (form) => {
    try {
      await fetch('/.netlify/functions/lead-email', {
        method: 'POST',
        body: new FormData(form)
      });
    } catch {
      // Netlify Forms already captured the lead; email is a secondary alert.
    }
  };

  contactForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    contactError.classList.add('hidden');
    contactText.textContent = 'ENVIANDO...';
    contactSpinner.classList.remove('hidden');
    contactSubmit.disabled = true;
    contactSubmit.classList.add('opacity-70', 'cursor-not-allowed');

    try {
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(contactForm)).toString()
      });

      if (!response.ok) {
        throw new Error('No se pudo enviar el formulario.');
      }

      await notifyLeadEmail(contactForm);
      window.location.href = '/gracias/';
    } catch {
      contactText.textContent = 'INTENTAR DE NUEVO';
      contactError.classList.remove('hidden');
      contactSpinner.classList.add('hidden');
      contactSubmit.disabled = false;
      contactSubmit.classList.remove('opacity-70', 'cursor-not-allowed');
    }
  });
</script>
