---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';

const services = [
  ['01', 'Identidad', 'Marcas con una base visual clara, flexible y reconocible.', ['Estrategia de marca', 'Identidad visual', 'Sistemas y guías']],
  ['02', 'Experiencia', 'Interfaces que hacen simple lo complejo y acompañan cada decisión.', ['UX/UI', 'Web y e-commerce', 'Design systems']],
  ['03', 'Producto', 'Desarrollo sólido para que el diseño llegue completo a producción.', ['Web a medida', 'CMS y plataformas', 'Integraciones y mantenimiento']],
];
---

<section id="services" class="border-b border-light/10 bg-dark px-6 py-24 text-light lg:px-12 lg:py-32 relative overflow-hidden">
  <div class="relative z-10 mx-auto max-w-7xl">
    <SectionHeader label="Servicios" variant="dark" description="Puedo entrar en un punto específico o acompañar el proyecto de punta a punta.">
      <Fragment slot="title">De la idea<br />al <span class="text-accent-blue">lanzamiento.</span></Fragment>
    </SectionHeader>
    <div class="mt-16">
      <div class="scroll-animate"><div class="line-reveal h-px bg-light/10 w-full"></div></div>
      {services.map(([number, title, description, features]) => (
        <article class:list={[`grid gap-6 border-b border-light/10 py-8 md:grid-cols-[.3fr_1fr_1fr_auto] md:items-start md:gap-8 lg:py-10 scroll-animate stagger-${number}`]}>
          <span class="font-display text-2xl font-bold text-accent-orange">{number}</span>
          <h3 class="font-display text-4xl font-bold uppercase tracking-tight sm:text-5xl">{title}</h3>
          <div>
            <p class="max-w-md text-lg leading-relaxed text-light/70">{description}</p>
            <ul class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-xs font-bold uppercase tracking-wide text-light/55">
              {features.map((feature) => <li>{feature}</li>)}
            </ul>
          </div>
          <Button href="/brief" variant="ghost" size="sm">Consultar <span class="ml-2 text-base" aria-hidden="true">↗</span></Button>
        </article>
      ))}
    </div>
  </div>
</section>
