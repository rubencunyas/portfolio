---
const brands = [
  { name: "Brother" },
  { name: "Roky's" },
  { name: "Vistony" },
  { name: "Berlitz" },
  { name: "Radiomar" },
  { name: "Ritmo Romántica" },
  { name: "Nueva Q" },
  { name: "Radio Planeta" },
  { name: "Radio Moda" },
  { name: "Organnical" },
  { name: "Futura Farms" },
  { name: "Sony Music" },
  { name: "Starbucks" },
  { name: "Sixt" }
];
---

<section class="py-16 lg:py-24 px-6 lg:px-12 border-b border-white/10 bg-dark scroll-animate opacity-0 translate-y-8">
  <div class="max-w-7xl mx-auto">
    <header class="mb-12">
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl tracking-tight text-white">
        MARCAS.
      </h2>
    </header>
    
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7 gap-6 lg:gap-8">
      {brands.map((brand) => (
        <div class="group flex items-center justify-center p-4 lg:p-6 border border-white/10 hover:border-accent-blue/50 bg-white/5 hover:bg-accent-blue/10 transition-all duration-300">
          <span class="grayscale group-hover:grayscale-0 text-center text-xs sm:text-sm text-white/50 group-hover:text-white font-medium uppercase tracking-wider transition-all duration-500">
            {brand.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
