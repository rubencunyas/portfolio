---
const brands = ['Brother', "Roky’s", 'Vistony', 'Berlitz', 'Radiomar', 'Sony Music', 'Starbucks', 'Organnical', 'Futura Farms', 'Autoval'];
---

<section class="border-b border-ink/10 bg-accent-blue px-6 py-16 text-light lg:px-12 lg:py-20 scroll-animate">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
      <h2 class="font-display text-4xl font-bold uppercase leading-none tracking-tight sm:text-5xl">Marcas que<br />han confiado.</h2>
      <p class="max-w-sm text-sm leading-relaxed text-light/75">Proyectos para empresas, equipos y personas que quieren hacer las cosas con intención.</p>
    </div>
    <div class="mt-12 flex flex-wrap border-l border-t border-light/25">
      {brands.map((brand) => <span class="flex min-h-16 flex-1 basis-1/2 items-center justify-center border-b border-r border-light/25 px-4 text-center text-sm font-bold uppercase tracking-wide sm:basis-1/3 lg:basis-1/5">{brand}</span>)}
    </div>
  </div>
</section>
