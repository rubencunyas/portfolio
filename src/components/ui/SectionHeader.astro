---
export interface Props {
  label?: string;
  title: string;
  description?: string;
  variant?: 'light' | 'dark';
  class?: string;
}

const { label, title, description, variant = 'light', class: className = '' } = Astro.props;

const labelColor = variant === 'dark' ? 'text-accent-orange' : 'text-accent-orange';
const titleColor = variant === 'dark' ? 'text-light' : 'text-ink';
const descColor = variant === 'dark' ? 'text-light/65' : 'text-ink/65';
---

<header class={`grid gap-6 lg:grid-cols-[1fr_2fr] lg:items-end scroll-animate ${className}`}>
  {label && <p class="text-sm font-bold uppercase tracking-widest text-accent-orange">{label}</p>}
  <div>
    <h2 class={`font-display text-5xl font-bold uppercase leading-[.88] tracking-[-0.02em] sm:text-6xl lg:text-7xl ${titleColor}`}>
      <slot name="title">{title}</slot>
    </h2>
    {description && (
      <p class={`mt-5 max-w-xl text-lg leading-relaxed ${descColor}`}>{description}</p>
    )}
    <slot name="extra" />
  </div>
</header>
