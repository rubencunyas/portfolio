---
const links = [
  { href: '#work', label: 'Proyectos' },
  { href: '#about', label: 'Perfil' },
  { href: '#services', label: 'Servicios' },
  { href: '#contact', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 border-b border-ink/10 bg-light/95 text-ink backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-[90rem] items-center justify-between px-5 sm:px-8 lg:px-12" aria-label="Navegación principal">
    <a href="/" class="flex items-center gap-3 font-display text-2xl font-bold uppercase tracking-tight" aria-label="Ir al inicio">
      <img src="/logo.svg" alt="" width="40" height="40" class="h-9 w-9" />
      <span>Rubén Cunyas</span>
    </a>
    <div class="hidden items-center gap-7 text-sm font-semibold uppercase tracking-wide md:flex">
      {links.map((link) => <a href={link.href} class="transition-colors hover:text-accent-blue">{link.label}</a>)}
    </div>
    <a href="#contact" class="inline-flex min-h-10 items-center bg-ink px-4 text-xs font-bold uppercase tracking-wider text-light transition-all duration-300 ease-out hover:bg-accent-blue hover:shadow-lg hover:shadow-accent-blue/20 active:scale-95 sm:px-5">
      Hablemos <span aria-hidden="true" class="ml-2">↗</span>
    </a>
  </nav>
</header>
