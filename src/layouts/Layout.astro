---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import WhatsApp from '../components/WhatsApp.astro';

const siteTitle = "Rubén Cunyas | Diseñador Digital y Desarrollador Full Stack";
const siteDescription = "Diseñador Digital y Desarrollador Full Stack con 13+ años de experiencia. Transformo ideas claras en soluciones digitales que funcionan. UX/UI, Branding, Desarrollo Web.";
const siteUrl = "https://cunyas.com";
const siteImage = `${siteUrl}/og-image.jpg`;
const authorName = "Rubén Cunyas";
const authorJob = "Diseñador Digital & Desarrollador Full Stack";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>Rubén Cunyas | Diseñador Digital y Desarrollador Full Stack</title>
    <meta name="description" content={siteDescription} />
    <meta name="author" content={authorName} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="diseñador digital, desarrollador full stack, UX/UI, branding, desarrollo web, Perú, Lima, diseño digital, freelancer" />
    <meta name="theme-color" content="#F8F6F0" />
    <meta name="generator" content={Astro.generator} />
    
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,500;0,700;1,500;1,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={siteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Rubén Cunyas" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={siteImage} />
    
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Rubén Cunyas",
        "jobTitle": "Diseñador Digital & Desarrollador Full Stack",
        "url": "https://cunyas.com",
        "sameAs": [
          "https://pe.linkedin.com/in/rubencunyas"
        ],
        "knowsAbout": ["Diseño Digital", "Desarrollo Full Stack", "UX/UI", "Branding"],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "LATAM",
          "addressCountry": "PE"
        }
      }
    </script>
    
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Rubén Cunyas Portfolio",
        "url": "https://cunyas.com",
        "description": "Diseñador Digital y Desarrollador Full Stack con 13+ años de experiencia.",
        "author": {
          "@type": "Person",
          "name": "Rubén Cunyas"
        }
      }
    </script>
    
    <ViewTransitions />
    
    <script>
      function initScrollAnimations() {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        document.querySelectorAll('.scroll-animate').forEach(el => {
          el.classList.remove('visible');
          observer.observe(el);
        });
      }
      
      initScrollAnimations();
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </head>
  <body class="bg-light text-ink font-sans antialiased">
    <slot />
    <WhatsApp />
  </body>
</html>

<style is:global>
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  ::selection {
    background-color: #3031E4;
    color: #ffffff;
  }
  
  :focus-visible {
    outline: 2px solid #3031E4;
    outline-offset: 2px;
  }
  
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  
  @keyframes slide-from-right {
    from { transform: translateX(30px); }
    to { transform: translateX(0); }
  }
  
  @keyframes slide-to-left {
    from { transform: translateX(0); }
    to { transform: translateX(-30px); }
  }
  
  ::view-transition-old(root) {
    animation: 90ms cubic-bezier(0.4, 0, 1, 1) both fade-out,
               90ms cubic-bezier(0.4, 0, 0.2, 1) both slide-to-left;
  }
  
  ::view-transition-new(root) {
    animation: 210ms cubic-bezier(0, 0, 0.2, 1) 90ms both fade-in,
               210ms cubic-bezier(0.4, 0, 0.2, 1) 90ms both slide-from-right;
  }
</style>
